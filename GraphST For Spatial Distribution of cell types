}
assert sum(frequencies.values()) == 0000
cell_type_list = []
for cell_type, freq in frequencies.items():
    cell_type_list.extend([cell_type] * freq)
data_singlecell.obs['cell_type'] = cell_type_list
project_cell_to_spot(data_spatial, data_singlecell, retain_percent=0.15)
data_spatial.write("Obj_Spatial.h5ad")

