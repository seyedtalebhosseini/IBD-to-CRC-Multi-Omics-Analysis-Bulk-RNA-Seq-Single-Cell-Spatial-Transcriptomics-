device = torch.device('cuda:1' if torch.cuda.is_available() else 'cpu')
os.environ['R_HOME'] = '/C:\Program Files\R\R-4.3.2'

dataset = "directory of samples"
file_fold = "spatial/" + str(dataset)
data_spatial = sc.read_visium(file_fold, count_file= "filtered_feature_bc_matrix.h5" , load_images=True)
data_spatial.var_names_make_unique()
GraphST.preprocess(data_spatial)
GraphST.construct_interaction(data_spatial)
GraphST.add_contrastive_label(data_spatial)
sc.pp.normalize_total(data_spatial, target_sum=1e4)
sc.pp.log1p(data_spatial)
sc.pp.highly_variable_genes(data_spatial, n_top_genes=2000)
data_spatial = data_spatial[:, data_spatial.var['highly_variable']]
data_singlecell = sc.read_h5ad("obj.h5ad")
data_singlecell.var_names_make_unique()
sc.pp.normalize_total(data_singlecell, target_sum=1e4)
data_singlecell.X[data_singlecell.X < 0] = 0
sc.pp.log1p(data_singlecell)
data_singlecell.X = np.nan_to_num(data_singlecell.X, nan=0.0, posinf=0.0, neginf=0.0)
sc.pp.filter_cells(data_singlecell, min_genes=1)
sc.pp.filter_genes(data_singlecell, min_cells=1)
sc.pp.highly_variable_genes(data_singlecell, n_top_genes=2000)
data_singlecell = data_singlecell[:, data_singlecell.var['highly_variable']]
GraphST.preprocess(data_singlecell)
from GraphST.preprocess import filter_with_overlap_gene
data_spatial, data_singlecell = filter_with_overlap_gene(data_spatial, data_singlecell)
GraphST.get_feature(data_spatial)
model = GraphST.GraphST(data_spatial, data_singlecell, epochs=1200, random_seed=50, device=device, deconvolution=True)
data_spatial, data_singlecell = model.train_map()
from GraphST.utils import project_cell_to_spot
cell_types = ['cell type 1','cell type 2', ....]
frequencies = {
